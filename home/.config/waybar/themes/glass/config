{
  "layer": "top",
  "exclusive": true,
  "position": "top",
  "margin-top": 9,
  "width": 1450,
  "reload_style_on_change": true,

  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "hyprland/workspaces",
    "custom/separator",
    "custom/mpris",
    "custom/separator",
    "clock",
    "custom/pomo",
    "pulseaudio",
    "backlight",
    "custom/memorypie",
    "battery",
    "tray",
    "custom/notification",
    "custom/exit"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "п„‘",
      "default": "п„‘",
      "empty": "п„‘"
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    },
    "tooltip": false
  },

  "hyprland/window": {
    "format": "{class}",
    "rewrite": {
      "^$": "Desktop"
    },
    "max-length": 15,
    "min-length": 15,
    "separate-outputs": true,
    "tooltip": false
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "custom/mpris": {
    "exec": "~/.config/waybar/themes/glass/mpris.sh",
    "interval": 2,
    "return-type": "json",
    "max-length": 25,
    "min-length": 25,
    "on-click": "playerctl play-pause",
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a, %d %b}",
    "tooltip": false
  },

  // "pulseaudio": {
  //   "format": "{icon}  {volume}%",
  //   "format-muted": "у°ќџ",
  //   "format-icons": {
  //     "default": ["пЂ¦", "пЂ§", "пЂЁ"]
  //   },
  //   "on-click": "pavucontrol",
  //   "tooltip": false
  // },

  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
    "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
    "format-muted": "пљ© {format_source}",
    "format-source": "{volume}% п„°",
    "format-source-muted": "п„±",
    "format-icons": {
      "headphone": "пЂҐ ",
      "hands-free": "п–ђ ",
      "headset": "п–ђ ",
      "phone": "п‚• ",
      "portable": "п‚• ",
      "car": "п†№ ",
      "default": [
        "пЂ¦ ",
        "пЂЁ ",
        "пЂЁ "
      ]
    },
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "],
    "on-scroll-up": "brightness.sh increase",
    "on-scroll-down": "brightness.sh decrease",
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },

  "custom/memorypie": {
    "exec": "~/.config/waybar/themes/glass/memory_pie.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": false
  },

  "custom/exit": {
    "format": "пЂ‘",
    "on-click": "wlogout -b 6 -m 500",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "пѓі",
      "none": "пѓі",
      "dnd-notification": "п‡·",
      "dnd-none": "п‡·",
      "inhibited-notification": "пЃЄ",
      "inhibited-none": "пЃЄ",
      "dnd-inhibited-notification": "п‡¶",
      "dnd-inhibited-none": "п‡¶"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "пѓ§ {capacity}%",
    "format-icons": ["у°‚ѓ", "у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚"],
    "tooltip": false
  },

  "custom/pomo": {
    "exec": "~/.config/waybar/themes/glass/pomo.sh",
    "on-click": "~/.config/waybar/themes/glass/pomo.sh toggle",
    "on-click-right": "~/.config/waybar/themes/glass/pomo.sh stop",
    "on-scroll-up": "~/.config/waybar/themes/glass/pomo.sh preset-next",
    "on-scroll-down": "~/.config/waybar/themes/glass/pomo.sh preset-prev",
    "interval": 1,
    "return-type": "json",
    "format": "{}",
    "tooltip": false
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  }
}
