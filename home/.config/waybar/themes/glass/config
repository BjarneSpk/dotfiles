{
  "layer": "top",
  "exclusive": true,
  "position": "top",
  "margin-top": 9,
  "width": 1450,
  "reload_style_on_change": true,

  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "hyprland/workspaces",
    "custom/separator",
    "custom/mpris",
    "custom/mpris-prev",
    "custom/mpris-next",
    "custom/separator",
    "clock",
    "custom/pomo",
    "pulseaudio",
    "backlight",
    "custom/memorypie",
    "battery",
    "tray",
    "custom/notification",
    "custom/exit"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "ï„‘",
      "default": "ï„‘",
      "empty": "ï„‘"
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    },
    "tooltip": false
  },

  "hyprland/window": {
    "format": "{class}",
    "rewrite": {
      "^$": "Desktop"
    },
    "max-length": 15,
    "min-length": 15,
    "separate-outputs": true,
    "tooltip": false
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "custom/mpris": {
    "exec": "~/.config/waybar/themes/glass/scripts/mpris.sh",
    "interval": 2,
    "return-type": "json",
    "escape": false,
    "max-length": 25,
    "min-length": 25,
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "tooltip": false
  },
  "custom/mpris-prev": {
    "format": "ïپˆ",
    "on-click": "playerctl previous",
    "tooltip": false
  },
  "custom/mpris-next": {
    "format": "ïپ‘",
    "on-click": "playerctl next",
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a, %d %b}",
    "tooltip": false
  },

  // "pulseaudio": {
  //   "format": "{icon}  {volume}%",
  //   "format-muted": "َ°‌ں",
  //   "format-icons": {
  //     "default": ["ï€¦", "ï€§", "ï€¨"]
  //   },
  //   "on-click": "pavucontrol",
  //   "tooltip": false
  // },

  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetooth": "{volume}% {icon}ïٹ” {format_source}",
    "format-bluetooth-muted": "ïڑ© {icon}ïٹ” {format_source}",
    "format-muted": "ïڑ© {format_source}",
    "format-source": "{volume}% ï„°",
    "format-source-muted": "ï„±",
    "format-icons": {
      "headphone": "ï€¥ ",
      "hands-free": "ï–گ ",
      "headset": "ï–گ ",
      "phone": "ï‚• ",
      "portable": "ï‚• ",
      "car": "ï†¹ ",
      "default": [
        "ï€¦ ",
        "ï€¨ ",
        "ï€¨ "
      ]
    },
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["َ°ƒ‍", "َ°ƒں", "َ°ƒ "],
    "on-scroll-up": "brightness.sh increase",
    "on-scroll-down": "brightness.sh decrease",
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },

  "custom/memorypie": {
    "exec": "~/.config/waybar/themes/glass/scripts/memory_pie.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": false
  },

  "custom/exit": {
    "format": "ï€‘",
    "on-click": "wlogout -b 6 -m 500",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "ïƒ³",
      "none": "ïƒ³",
      "dnd-notification": "ï‡·",
      "dnd-none": "ï‡·",
      "inhibited-notification": "ïپھ",
      "inhibited-none": "ïپھ",
      "dnd-inhibited-notification": "ï‡¶",
      "dnd-inhibited-none": "ï‡¶"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "ïƒ§ {capacity}%",
    "format-icons": ["َ°‚ƒ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚"],
    "tooltip": false
  },

  "custom/pomo": {
    "exec": "~/.config/waybar/themes/glass/scripts/pomo.sh",
    "on-click": "~/.config/waybar/themes/glass/scripts/pomo.sh toggle",
    "on-click-right": "~/.config/waybar/themes/glass/scripts/pomo.sh stop",
    "on-scroll-up": "~/.config/waybar/themes/glass/scripts/pomo.sh preset-next",
    "on-scroll-down": "~/.config/waybar/themes/glass/scripts/pomo.sh preset-prev",
    "interval": 1,
    "return-type": "json",
    "format": "{}",
    "tooltip": false
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  }
}
