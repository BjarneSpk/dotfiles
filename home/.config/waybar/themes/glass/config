{
  "layer": "top",
  "exclusive": true,
  "position": "top",
  "margin-top": 9,
  "width": 1450,
  "reload_style_on_change": true,

  "modules-center": [
    "hyprland/window",
    "custom/separator",
    "hyprland/workspaces",
    "custom/separator",
    "custom/mpris",
    "custom/mpris-prev",
    "custom/mpris-toggle",
    "custom/mpris-next",
    "custom/separator",
    "clock",
    "custom/pomo",
    "pulseaudio",
    "backlight",
    "custom/memorypie",
    "battery",
    "tray",
    "custom/notification",
    "custom/exit"
  ],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "´äĹ",
      "default": "´äĹ",
      "empty": "´äĹ"
    },
    "persistent-workspaces": {
      "*": [1, 2, 3, 4, 5]
    },
    "tooltip": false
  },

  "hyprland/window": {
    "format": "{class}",
    "rewrite": {
      "^$": "Desktop"
    },
    "max-length": 15,
    "min-length": 15,
    "separate-outputs": true,
    "tooltip": false
  },

  "custom/separator": {
    "format": "|",
    "tooltip": false
  },

  "custom/mpris": {
    "exec": "~/.config/waybar/themes/glass/scripts/mpris.sh",
    "interval": 2,
    "return-type": "json",
    "escape": false,
    "max-length": 25,
    "min-length": 25,
    "tooltip": false
  },
  "custom/mpris-prev": {
    "format": "´üł",
    "on-click": "playerctl previous",
    "tooltip": false
  },
  "custom/mpris-toggle": {
    "exec": "~/.config/waybar/themes/glass/scripts/mpris_toggle.sh",
    "exec-if": "playerctl -l",
    "interval": 2,
    "return-type": "json",
    "on-click": "playerctl play-pause",
    "tooltip": false
  },
  "custom/mpris-next": {
    "format": "´üĹ",
    "on-click": "playerctl next",
    "tooltip": false
  },

  "clock": {
    "format": "{:%H:%M}",
    "format-alt": "{:%a, %d %b}",
    "tooltip": false
  },

  // "pulseaudio": {
  //   "format": "{icon}  {volume}%",
  //   "format-muted": "ˇ░Łč",
  //   "format-icons": {
  //     "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
  //   },
  //   "on-click": "pavucontrol",
  //   "tooltip": false
  // },

  "pulseaudio": {
    "format": "{volume}% {icon}  {format_source}",
    "format-bluetooth": "{volume}% {icon}´Őö {format_source}",
    "format-bluetooth-muted": "´Üę {icon}´Őö {format_source}",
    "format-muted": "´Üę {format_source}",
    "format-source": "{volume}% ´ä░",
    "format-source-muted": "´ä▒",
    "format-icons": {
      "headphone": "´Çą ",
      "hands-free": "´ľÉ ",
      "headset": "´ľÉ ",
      "phone": "´éĽ ",
      "portable": "´éĽ ",
      "car": "´ć╣ ",
      "default": [
        "´ÇŽ ",
        "´ÇĘ ",
        "´ÇĘ "
      ]
    },
    "on-click": "pavucontrol"
  },
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["ˇ░â×", "ˇ░âč", "ˇ░âá"],
    "on-scroll-up": "brightness.sh increase 5",
    "on-scroll-down": "brightness.sh decrease 5",
    "smooth-scrolling-threshold": 0.2,
    "tooltip": false
  },

  "custom/memorypie": {
    "exec": "~/.config/waybar/themes/glass/scripts/memory_pie.sh",
    "interval": 2,
    "return-type": "json",
    "tooltip": false
  },

  "custom/exit": {
    "format": "´ÇĹ",
    "on-click": "wlogout -b 6 -m 500",
    "on-click-right": "hyprlock",
    "tooltip-format": "Left: Power menu\nRight: Lock screen"
  },
  "custom/notification": {
    "tooltip-format": "Left: Notifications\nRight: Do not disturb",
    "format": "{icon}",
    "format-icons": {
      "notification": "´â│",
      "none": "´â│",
      "dnd-notification": "´çĚ",
      "dnd-none": "´çĚ",
      "inhibited-notification": "´ü¬",
      "inhibited-none": "´ü¬",
      "dnd-inhibited-notification": "´çÂ",
      "dnd-inhibited-none": "´çÂ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "´âž {capacity}%",
    "format-icons": ["ˇ░éâ", "ˇ░ü║", "ˇ░ü╗", "ˇ░ü╝", "ˇ░üŻ", "ˇ░üż", "ˇ░ü┐", "ˇ░éÇ", "ˇ░éü", "ˇ░éé"],
    "tooltip": false
  },

  "custom/pomo": {
    "exec": "~/.config/waybar/themes/glass/scripts/pomo.sh",
    "on-click": "~/.config/waybar/themes/glass/scripts/pomo.sh toggle",
    "on-click-right": "~/.config/waybar/themes/glass/scripts/pomo.sh stop",
    "on-scroll-up": "~/.config/waybar/themes/glass/scripts/pomo.sh preset-next",
    "on-scroll-down": "~/.config/waybar/themes/glass/scripts/pomo.sh preset-prev",
    "interval": 1,
    "return-type": "json",
    "format": "{}",
    "tooltip": false
  },

  "tray": {
    "spacing": 8,
    "tooltip": false
  }
}
